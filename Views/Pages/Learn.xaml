<Page x:Class="Uperclaw.Views.Pages.Learn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uperclaw.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Learn">

    <Grid>
        <StackPanel>
            <Expander Header="{DynamicResource Learn_Q1}">
                <Grid>
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="{DynamicResource Learn_Q1_Answer}"/>
                        <Hyperlink>
                            <ui:SymbolIcon Symbol="ShoppingBag24"/>
                        </Hyperlink>
                        <Run Text="{DynamicResource Learn_Q1_Answer_Suffix}"/>
                    </TextBlock>
                </Grid>
            </Expander>
            <Expander Header="{DynamicResource Learn_Q2}">
                <Grid>
                    <TextBlock Text="{DynamicResource Learn_Q2_Answer}" TextWrapping="Wrap"/>
                </Grid>
            </Expander>
            <Expander Header="{DynamicResource Learn_Q3}">
                <Grid>
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="{DynamicResource Learn_Q3_Answer_Prefix}"/>
                        <Hyperlink>
                            <Run Text="http://127.0.0.1:11434"/>
                        </Hyperlink>
                        <Run Text="{DynamicResource Learn_Q3_Answer_Suffix}"/>
                    </TextBlock>
                </Grid>
            </Expander>
            <Expander Header="{DynamicResource Learn_Q4}">
                <Grid>
                    <TextBlock Text="{DynamicResource Learn_Q4_Answer}" TextWrapping="Wrap"/>
                </Grid>
            </Expander>
            <Expander Header="{DynamicResource Learn_Q5}">
                <Grid>
                    <TextBlock Text="{DynamicResource Learn_Q5_Answer}" TextWrapping="Wrap"/>
                </Grid>
            </Expander>
            <Expander Header="{DynamicResource Learn_Q6}">
                <Grid>
                    <TextBlock Text="{DynamicResource Learn_Q6_Answer}" TextWrapping="Wrap"/>
                </Grid>
            </Expander>
        </StackPanel>
    </Grid>
</Page>