<Page x:Class="Uperclaw.Views.Pages.Console"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uperclaw.Views.Pages"
      mc:Ignorable="d" 
      Loaded="Page_Loaded"
      xmlns:cmds="clr-namespace:Wpf.Ui.Terminal;assembly=Wpf.Ui.Terminal"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Console">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ui:Card x:Name="StartProcess">
            <WrapPanel>
                <Button x:Name="StartButton" Click="StartButton_Click">
                    <WrapPanel>
                        <ui:SymbolIcon Symbol="CalendarWeekStart24"/>
                        <ui:TextBlock Text="{DynamicResource ResourceKey=Start}"/>
                    </WrapPanel>
                </Button>
                <Button Margin="2,0,0,0" x:Name="StopButton" Click="StopButton_Click">
                    <WrapPanel>
                        <ui:SymbolIcon Symbol="Bug24"/>
                        <ui:TextBlock Text="{DynamicResource ResourceKey=Stop}"/>
                    </WrapPanel>
                </Button>
                <CheckBox x:Name="UseInput" IsChecked="True">
                    <Grid>
                        <ui:SymbolIcon Symbol="Keyboard12320"/>
                        <ui:SymbolIcon Symbol="TextSortAscending24"/>
                    </Grid>
                </CheckBox>
            </WrapPanel>
        </ui:Card>
        <Border Margin="2" CornerRadius="5" Background="Black" Grid.Row="1">
            <cmds:ExtendedTerminalControl x:Name="PowershellBox" IsReadOnly="{Binding ElementName=UseInput,Path=IsChecked}"  Margin="5">

            </cmds:ExtendedTerminalControl>
        </Border>
    </Grid>
</Page>
